# NOWHERE.ai FastAPI backend — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit
# real keys. On a PaaS host (Render/Railway/Fly) set these in the host's env UI
# instead of a file.
#
# IMPORTANT — config.py uses pydantic-settings with extra="forbid": ANY env var
# not declared in Settings crashes the app on boot. Keep this list to declared
# fields only. The AGENCY_OLLAMA_* cloud creds are NOT declared in Settings, so
# they MUST live in `.agency.env` (see .agency.env.example), NOT here — putting
# them in .env crashes the boot AND pydantic echoes the value into the trace.

# ---- Core ----
ENVIRONMENT=production
DEBUG=false

# ---- Database (MongoDB Atlas in prod) ----
MONGO_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=nowhere_digital

# ---- CORS (CRITICAL: must be a JSON array string, not comma-separated) ----
# config.py parses CORS_ORIGINS as JSON because the field is typed List[str].
# A comma string is NOT valid JSON → boot crash. Include your frontend URL(s)
# + localhost for dev. Keep the inner quotes.
CORS_ORIGINS=["https://<project>.pages.dev","http://localhost:3000"]

# ---- Auth ----
# Strong random value. Used to sign JWTs (security_manager reads settings.jwt_secret).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-strong-random-secret

# ---- AI / LLM (optional — backend degrades to fallback text without a key) ----
# The AI solver / chat / Dubai-analysis return real LLM output when one of these
# is set. EMERGENT_LLM_KEY is the repo's default provider.
EMERGENT_LLM_KEY=
AI_PROVIDER=emergent
# OPENAI_API_KEY=

# ---- Payments (Stripe) ----
# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # needed by POST /api/integrations/payments/webhook

# ---- WhatsApp / SMS (Twilio) ----
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox WhatsApp sender

# ---- Email (SendGrid) ----
# SENDGRID_API_KEY=

# ---- Plugins (only override outside Docker; /app/plugins is the container path) ----
# PLUGINS_DIRECTORY=/app/plugins